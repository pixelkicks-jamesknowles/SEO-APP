// pixelify-seo data. Postgres in every environment (parity with pixelify-admin):
// SQLite is not viable in prod — the session store holds each shop's offline token,
// wiped on every redeploy on a container/serverless host. DATABASE_URL is set in env.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session storage (@shopify/shopify-app-session-storage-prisma).
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Per-shop install + billing snapshot. No business data — SEO config lives below;
// products/collections/metafields stay in Shopify.
model Shop {
  shopDomain                String    @id
  plan                      String? // free | starter | growth | pro
  subscriptionGid           String?
  billingStatus             String?
  installedAt               DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  // Single-use, short-TTL nonce for the Google Ads OAuth `state` (CSRF + replay protection). Minted
  // when the connect flow starts, consumed (and cleared) by the callback. See google-ads.server.js.
  googleOauthNonce          String?
  googleOauthNonceExpiresAt DateTime?
}

// Tracking module settings (spec seo-app-v1 §9). Platform IDs + per-platform event
// matrix + consent. Web Pixel reads an effective copy via app proxy / metafield.
model TrackingSettings {
  shopDomain           String   @id
  gtmId                String?
  ga4Id                String?
  metaPixelId          String?
  tiktokPixelId        String?
  pinterestId          String?
  snapPixelId          String?
  redditPixelId        String? // Reddit pixel / advertiser id for the Conversions API path
  bingUetId            String?
  // LinkedIn Conversions API: the conversion-rule id (numeric, or a full urn:lla:llaPartnerConversion:<id>).
  // The access token lives (encrypted) in serverSideKeys.linkedinAccessToken. B2B server-side conversions.
  linkedinConversionId String?
  // Per-platform event opt-in, e.g. {"ga4":["page_viewed","product_viewed","checkout_completed"]}
  eventMatrix          String   @default("{}") // JSON
  consentMode          Boolean  @default(true) // respect Customer Privacy consent at all
  // Consent Mode v2: when true (and consentMode on), still send consent-FLAGGED events without
  // consent (GA4 models the gap; Meta is skipped without marketing consent) instead of suppressing.
  consentSignals       Boolean  @default(true)
  serverSide           Boolean  @default(false) // Meta CAPI / GA4 MP / server GTM (Pro tier)
  serverSideKeys       String? // JSON: encrypted server-side credentials
  webPixelId           String? // gid of the WebPixel created via webPixelCreate (create-once, then update)
  // Server-side subscription conversion event (orders/paid → GA4). See seo-subscription-tracking-v1.
  subscriptionTracking Boolean  @default(false)
  subscriptionConfig   String   @default("{}") // JSON: { eventName, monthDays, respectConsent, clientIdMode }
  pixelDebug           Boolean  @default(false) // log every event in the storefront console (testing)
  // Send a GA4 `refund` event from refunds/create + orders/cancelled (negative conversions).
  refundTracking       Boolean  @default(false)
  // Drop known bot / headless traffic before server-side delivery (default on).
  botFiltering         Boolean  @default(true)
  // Value-based optimisation: send margin (revenue × marginPct) as the conversion `value` instead of
  // raw revenue, so ad platforms optimise for profit. Opt-in; raw revenue kept as a `revenue` param.
  valueMode            String   @default("revenue") // "revenue" | "margin"
  marginPct            Int      @default(0) // whole percent, applied when valueMode = "margin"
  // Multi-currency normalization: convert every conversion's value/currency to reportingCurrency
  // before delivery so ad platforms optimise on comparable numbers across markets. Off by default.
  reportingCurrency    String? // ISO 4217, e.g. "USD"; null → no normalization
  fxMode               String   @default("off") // "off" | "on"
  // Post-purchase & lifecycle events (orders/edited value delta, fulfillments/create → GA4). Opt-in.
  lifecycleTracking    Boolean  @default(false)
  // Google Ads Enhanced Conversions (direct upload via the Google Ads API). Gated: inert unless the
  // GOOGLE_ADS_* / GOOGLE_OAUTH_* env vars are set AND the merchant has connected + configured below.
  googleAdsEnabled     Boolean  @default(false)
  googleAdsConfig      String   @default("{}") // JSON: { customerId, loginCustomerId, conversionActionId }
  // Server-side purchase reconciliation: orders/paid records every paid order; a delayed cron pass
  // backfills the GA4/Meta purchase for any order the storefront pixel never delivered (ad blockers,
  // sandbox init failures, ITP), deduped so it can only fill gaps. On by default; only acts when
  // serverSide is on. TikTok Events API + Pinterest CAPI credentials live in serverSideKeys (JSON).
  reconciliation       Boolean  @default(true)
  // GTM web-container data layer (Pro): the theme app embed pushes GA4-standard + Elevar-compatible
  // dl_* ecommerce events (view_item / add_to_cart / begin_checkout …) to window.dataLayer on the
  // storefront. Purchase is NOT emitted here (Shopify's checkout is no longer themeable) — it stays
  // server-side. Gated behind requirePro at toggle time; the storefront reads the effective flag from
  // the app-proxy /config endpoint so it can't be enabled from the theme editor to bypass billing.
  dataLayerEnabled     Boolean  @default(false)
  // Proactive health alerting: an incoming-webhook URL (Slack / Discord / Teams / generic) the cron posts
  // to when a tracking-health alert fires (dead-lettered sends, capture/delivery drops, outbox backlog),
  // so a merchant hears about a broken pixel without opening the app. Off (null) → in-app banners only.
  alertWebhookUrl      String?
  updatedAt            DateTime @updatedAt
}

// Per-(shop, alert kind) notify dedup: the cron records when it last pushed an alert to the webhook, so a
// still-firing condition is re-notified at most once per cooldown window (not every tick). Distinct from
// AlertDismissal (which silences the in-app banner) — this governs the OUTBOUND webhook only.
model AlertNotification {
  shopDomain String
  kind       String // outbox_dead | no_captures | capture_low | delivery_low | outbox_backlog
  notifiedAt DateTime @default(now())

  @@id([shopDomain, kind])
}

// Per-destination delivery outcomes for the in-app health panel (success/failure of each server-side
// send). Capped per shop at write time. Powers the "Delivery health" view.
model DeliveryLog {
  id          String   @id @default(uuid())
  shopDomain  String
  destination String // ga4 | meta | gtm | ga4_subscription | ga4_refund
  eventName   String
  ok          Boolean
  detail      String? // HTTP status or error summary
  createdAt   DateTime @default(now())

  @@index([shopDomain, createdAt])
}

// Durable retry queue for server-side sends. When a delivery fails (transient 5xx / network), the
// PLATFORM-READY event is queued here (no secrets — those are re-read from TrackingSettings at retry
// time, so credential rotation is safe) and re-sent by the /cron/tick worker with exponential backoff.
// A row that never succeeds is dead-lettered (status = "dead") after the last attempt.
model DeliveryOutbox {
  id            String   @id @default(uuid())
  shopDomain    String
  destination   String // ga4 | meta | gtm | google_ads | ga4_refund ...
  eventName     String
  payload       String // JSON: the built platform event + { clientId, consent, ... } needed to re-send
  attempts      Int      @default(0)
  status        String   @default("pending") // pending | delivered | dead
  lastDetail    String?
  nextAttemptAt DateTime @default(now())
  // Per-drain claim token: the cron worker stamps this when it leases a batch, then re-selects only the
  // rows carrying its token, so two overlapping ticks can't process (and re-send) the same row.
  leaseToken    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([shopDomain])
}

// Daily FX snapshot for multi-currency normalization. One row per (base, date); `rates` is a JSON map
// of quote-currency → rate. Refreshed once/day by the cron from a free FX endpoint.
model FxRate {
  base      String
  date      String // YYYY-MM-DD (UTC)
  rates     String // JSON: { "EUR": 0.92, "GBP": 0.79, ... }
  fetchedAt DateTime @default(now())

  @@id([base, date])
}

// Per-shop alert dismissal, so a merchant can silence an in-app health banner. Re-armed after a
// window (checked in computeHealth) so a recurring problem surfaces again rather than staying hidden.
model AlertDismissal {
  shopDomain  String
  kind        String // capture_low | delivery_low | outbox_backlog | no_captures
  dismissedAt DateTime @default(now())

  @@id([shopDomain, kind])
}

// First-touch attribution per customer, captured on the FIRST order we see and replayed onto every
// later (recurring) order — so subscription_purchase events inherit the original GA4 client_id +
// source/medium/campaign instead of looking like brand-new direct traffic (seo-subscription-tracking-v1 M2).
model CustomerAttribution {
  shopDomain   String
  customerKey  String // customer gid/id, or hashed email when no customer is attached
  clientId     String? // GA4 client_id captured at first checkout (ga_client_id / cookie)
  source       String?
  medium       String?
  campaign     String?
  firstOrderId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@id([shopDomain, customerKey])
}

// Per-day reconciliation counters per shop, powering the Accuracy dashboard. ordersPaid comes from
// the orders/paid webhook (Shopify's source of truth); purchasesDelivered counts checkout_completed
// events we delivered to >=1 destination; eventsSent/Failed are total server-side send outcomes.
model TrackingDaily {
  shopDomain         String
  date               String // YYYY-MM-DD (UTC)
  ordersPaid         Int      @default(0)
  purchasesDelivered Int      @default(0)
  eventsSent         Int      @default(0)
  eventsFailed       Int      @default(0)
  // Purchases the storefront pixel never captured that the reconciliation pass backfilled server-side,
  // and their summed order value — the recovered-revenue headline on the Accuracy page.
  purchasesRecovered Int      @default(0)
  revenueRecovered   Float    @default(0)
  updatedAt          DateTime @updatedAt

  @@id([shopDomain, date])
}

// First-touch attribution per anonymous visitor (keyed on the GA4 client_id), so a conversion in a
// later/direct session still carries its original source/medium/campaign instead of looking direct.
// Written only when a visit arrives with UTMs (first-touch is never overwritten).
model VisitorAttribution {
  shopDomain   String
  clientId     String
  // First-touch (never overwritten) + last-touch (latest UTM visit) for multi-touch attribution.
  source       String?
  medium       String?
  campaign     String?
  lastSource   String?
  lastMedium   String?
  lastCampaign String?
  visits       Int      @default(1) // UTM-tagged visits = touch count
  firstSeen    DateTime @default(now())
  lastSeen     DateTime @updatedAt

  @@id([shopDomain, clientId])
}

// Identity graph — links a durable first-party id (pxp_id, ITP-proof) to the GA4 client id it was last
// seen with AND to a customer once the visitor identifies (checkout/login). This is what turns per-session
// tracking into per-PERSON tracking: a returning visitor whose _ga churned still maps to one durableId,
// and a customer signing in on a second device links that device's durableId to the same customerKey —
// so a conversion inherits the whole cross-session/cross-device journey instead of looking like new
// direct traffic. clientId/customerKey are only ever set (never nulled) as more is learned.
model VisitorIdentity {
  shopDomain  String
  durableId   String
  clientId    String? // most recent GA4 client id seen for this durable id
  customerKey String? // customer id / hashed email, set once the visitor identifies (attribution.customerKey shape)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @updatedAt

  @@id([shopDomain, durableId])
  @@index([shopDomain, customerKey])
}

// Per-day revenue attributed to an acquisition channel (first-touch source/medium), bumped on each
// pixel-captured checkout_completed with the raw order value. Powers the "Revenue by channel" table on
// the Attribution page — turning first-touch counts into first-touch REVENUE (which channels actually
// drive sales, not just visits). Source/medium default to "(direct)"/"(none)" so every order lands in a row.
model ChannelRevenueDaily {
  shopDomain          String
  date                String // YYYY-MM-DD (UTC)
  source              String
  medium              String
  orders              Int      @default(0)
  revenue             Float    @default(0)
  // Subscription split. Recurring renewals never fire a storefront checkout, so GA4 structurally cannot
  // give them a channel (no browser session to inherit a source from) — but WE can: the customer's
  // first-touch source is replayed onto every renewal. This is the answer to "which channel actually
  // drove our subscription revenue", and it's the number GA4 will only ever report as Unassigned.
  // One-off revenue = revenue - subscriptionRevenue.
  subscriptionOrders  Int      @default(0)
  subscriptionRevenue Float    @default(0)
  updatedAt           DateTime @updatedAt

  @@id([shopDomain, date, source, medium])
  @@index([shopDomain, date])
}

// Historical revenue-by-channel backfill. ChannelRevenueDaily only fills from orders/paid going forward,
// so the Attribution report starts empty — and a subscription business's key question ("which channel
// acquired the subscribers whose renewals pay us now?") is answered by orders placed long before install.
// This job pages Shopify's order history (oldest-first, so a customer's earliest order is seen first and
// becomes their first touch), rebuilds the daily rollup, and populates CustomerAttribution so FUTURE
// renewals inherit the right channel too.
//
// Resumable: `cursor` is the Shopify page cursor. Leased like the other cron work so two ticks can't run
// it twice. Rows for days < today are cleared on a fresh start (cursor null) so a re-run can't double-count;
// the live orders/paid path owns today onward, so the two never overlap.
model BackfillJob {
  shopDomain      String    @id
  status          String    @default("idle") // idle | running | done | error
  cursor          String? // Shopify pagination cursor (null = not started / finished)
  sinceDate       String? // YYYY-MM-DD — REVENUE window start (what the report rebuilds)
  // YYYY-MM-DD — HISTORY scan start. Deliberately much older than sinceDate: an established subscriber's
  // ACQUIRING order (the only one that ever carried a customer journey) is often a year+ old, so scanning
  // only the revenue window means we never learn their channel and every renewal since lands in
  // (unattributed). We scan far back to LEARN first-touch, but only aggregate revenue from sinceDate.
  historySince    String?
  ordersProcessed Int       @default(0)
  // Diagnostic for the (unattributed) bucket (JSON, see backfill.js emptyUnattributed). Without this,
  // whoever reads the report WILL assume the unknowns are organic or direct — the two most flattering
  // guesses — and nothing would contradict them. This says exactly WHY we don't know: how many are
  // renewals whose acquiring order carried no journey, how many are guests, and the date span.
  breakdown       String    @default("{}")
  detail          String? // last error / summary
  leaseToken      String?
  leasedUntil     DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  updatedAt       DateTime  @updatedAt
}

// The individual orders that landed in the (unattributed) bucket during the backfill, so the report can
// LIST and EXPORT them rather than only show an aggregate — and, critically, split "migrated in from
// another platform" (imported orders that never had a Shopify journey; expected, permanent) from genuinely
// lost tracking. Rebuilt each run: cleared on a fresh start alongside ChannelRevenueDaily, windowed to
// sinceDate. Keyed on the numeric orderId so a re-run upserts rather than duplicates.
model UnattributedOrder {
  shopDomain     String
  orderId        String // numeric Shopify order id
  name           String? // #NATS0283210 etc
  date           String // YYYY-MM-DD
  revenue        Float    @default(0)
  isSubscription Boolean  @default(false)
  source         String? // admin "Source" (creating app name, e.g. "Matrixify App" / "Online Store")
  migrated       Boolean  @default(false) // source looks like a store-migration/import tool
  reason         String // known_customer_no_journey | guest_no_journey
  customerKey    String?
  updatedAt      DateTime @updatedAt

  @@id([shopDomain, orderId])
  @@index([shopDomain, date])
}

// Inbound-webhook idempotency (Shopify can deliver >once). Keyed on X-Shopify-Webhook-Id (fallback:
// order id). Purged on a TTL by the existing cron.audit job.
model ProcessedWebhook {
  webhookId  String   @id
  shopDomain String
  topic      String
  at         DateTime @default(now())

  @@index([shopDomain, at])
}

// Audit trail of merchant/app actions (saves, applies, redirects) for governance + support.
model ActivityLog {
  id         String   @id @default(uuid())
  shopDomain String
  action     String
  detail     String?
  createdAt  DateTime @default(now())

  @@index([shopDomain, createdAt])
}

// Google OAuth tokens per shop (Google Ads Enhanced Conversions). Written by the OAuth callback
// (google.oauth.callback.jsx) and read by google-ads.server.js for the direct conversion upload.
model GoogleToken {
  shopDomain   String    @id
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  updatedAt    DateTime  @updatedAt
}

// Server-side purchase reconciliation queue. orders/paid inserts one row per paid order (the trimmed
// order payload needed to rebuild the GA4/Meta purchase). A delayed cron pass (grace window) checks
// PurchaseCapture: any destination the storefront pixel never delivered is backfilled server-side, then
// the row is marked reconciled. GA4 dedups on transaction_id (= order id) and Meta on a deterministic
// event_id (= "order:<id>"), so a backfill can only fill a gap — never double-count.
model PendingPurchase {
  shopDomain  String
  orderId     String // numeric order id (Shopify's source of truth)
  payload     String // JSON: trimmed order fields (line items, totals, hashed-able identifiers)
  status      String    @default("pending") // pending | reconciled | skipped
  detail      String? // what the reconcile pass did (destinations sent / why skipped)
  // Per-pass claim token, mirroring DeliveryOutbox: the reconcile worker leases a batch (stamps this +
  // pushes leasedUntil out), then processes only rows carrying its token, so two overlapping cron ticks
  // can't both backfill (and double-count the recovered revenue of) the same order.
  leaseToken  String?
  leasedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@id([shopDomain, orderId])
  @@index([status, createdAt])
}

// A paid order awaiting deferred subscription processing. The orders/paid webhook must ACK Shopify in
// well under its 5s timeout, but resolving the order's selling plans (Admin API), COGS, FX and firing
// the two server-side GA4 conversions is slow — so the webhook only records this row (encrypted raw
// order payload) and returns 200; /cron/tick's processPendingSubscriptions does the heavy work off the
// hot path. Leased exactly like PendingPurchase so overlapping ticks can't double-send. Idempotent on
// (shop, order). Rows are purged after they're processed.
model PendingSubscription {
  shopDomain  String
  orderId     String // numeric order id
  payload     String // encrypted JSON of the raw Shopify order (carries PII → encryptSecret at rest)
  status      String    @default("pending") // pending | done | skipped | failed
  detail      String? // what the pass did (sent / why skipped)
  leaseToken  String?
  leasedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@id([shopDomain, orderId])
  @@index([status, createdAt])
}

// Which destinations already delivered a purchase for an order, keyed on the numeric order id. Upserted
// from the storefront-pixel checkout_completed delivery (ingest) AND the subscription webhook purchase,
// so the reconcile pass knows exactly which per-destination purchases are missing and fills only those.
model PurchaseCapture {
  shopDomain String
  orderId    String
  ga4        Boolean  @default(false)
  meta       Boolean  @default(false)
  // Google Ads + Reddit are also reconciled/backfilled (both have reliable server-side dedup: Google Ads
  // on orderId, Reddit on the order-scoped conversion_id), so they carry their own capture flag too.
  googleAds  Boolean  @default(false)
  reddit     Boolean  @default(false)
  at         DateTime @default(now())

  @@id([shopDomain, orderId])
  @@index([shopDomain, at])
}

// Per-day Meta identifier-coverage counters for the match-quality diagnostics (Event Match Quality is
// driven by how many identifiers each purchase carries). Bumped on every checkout_completed: `purchases`
// is the denominator, each identifier column counts purchases that carried it. Coverage % = col/purchases.
model MatchQualityDaily {
  shopDomain String
  date       String // YYYY-MM-DD (UTC)
  purchases  Int      @default(0)
  em         Int      @default(0)
  ph         Int      @default(0)
  fn         Int      @default(0)
  ln         Int      @default(0)
  ct         Int      @default(0)
  st         Int      @default(0)
  zp         Int      @default(0)
  country    Int      @default(0)
  externalId Int      @default(0)
  fbp        Int      @default(0)
  fbc        Int      @default(0)
  clientIp   Int      @default(0)
  userAgent  Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@id([shopDomain, date])
}

// Background-worker liveness. One `_global` row, upserted at the end of every /cron/tick, so the app can
// tell whether the scheduled worker is running (drives delivery retries, reconciliation, subscription
// conversions). A stale row → the dashboard tile + a cron_stale health alert. See heartbeat.server.js.
model CronHeartbeat {
  scope      String   @id @default("_global")
  lastTickAt DateTime @default(now())
  durationMs Int      @default(0)
  jobs       String   @default("{}") // JSON: per-sub-job summary of the last tick
  errors     String? // JSON: [{ job, message }] from the last tick, null when clean
  updatedAt  DateTime @updatedAt
}

// Recent storefront events forwarded by the Web Pixel (server-side beacon), for the live
// event debugger. Capped per shop at write time. Empty until the app proxy is live (deployed).
model RecentEvent {
  id         String   @id @default(uuid())
  shopDomain String
  name       String
  platform   String?
  payload    String
  createdAt  DateTime @default(now())

  @@index([shopDomain, createdAt])
}
