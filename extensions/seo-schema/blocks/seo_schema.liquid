{%- comment -%}
  Pixelify SEO — structured data app embed (target: head). Server-rendered JSON-LD, so it's
  crawlable and SEO-safe on ANY theme. Each node has a toggle so the merchant avoids the
  double-schema penalty (the app's audit flags duplicates the theme already emits — the
  single-emitter rule). AggregateRating reads the Reviews app's PUBLISHED metafield; it is
  never read from another app directly.

  NOTE: head app embeds receive `product` / `collection` on their templates. If a host theme
  doesn't expose them in head, switch this block to target "body" or ship it as an app block
  in the product template.
{%- endcomment -%}

{%- liquid
  assign ns = block.settings.rating_namespace
  assign rkey = block.settings.rating_key
  assign rckey = block.settings.rating_count_key
-%}

{%- if block.settings.enable_organization -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ block.settings.org_name | default: shop.name | json }},
    "url": {{ shop.url | json }}
    {%- if block.settings.org_logo != blank %},
    "logo": {{ block.settings.org_logo | image_url: width: 512 | prepend: 'https:' | json }}
    {%- endif -%}
    {%- if block.settings.org_sameas != blank %},
    "sameAs": [{% assign links = block.settings.org_sameas | split: ',' %}{% for l in links %}{{ l | strip | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- if product and block.settings.enable_product -%}
  {%- assign v = product.selected_or_first_available_variant -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "image": [{% for img in product.images limit: 5 %}{{ img | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
    {%- if v.sku != blank %}"sku": {{ v.sku | json }},{%- endif %}
    "brand": { "@type": "Brand", "name": {{ product.vendor | default: shop.name | json }} },
    "offers": {
      "@type": "Offer",
      "url": {{ shop.url | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": "{{ v.price | divided_by: 100.0 }}",
      "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
    }
    {%- if block.settings.enable_aggregate_rating -%}
      {%- assign r = product.metafields[ns][rkey] -%}
      {%- assign rc = product.metafields[ns][rckey] -%}
      {%- if r != blank and rc != blank and rc.value > 0 -%}
    ,"aggregateRating": { "@type": "AggregateRating", "ratingValue": "{{ r.value }}", "reviewCount": "{{ rc.value }}" }
      {%- endif -%}
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- if product and block.settings.enable_breadcrumb and product.collections.first -%}
  {%- assign col = product.collections.first -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": {{ col.title | json }}, "item": {{ shop.url | append: col.url | json }} },
      { "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
    ]
  }
  </script>
{%- endif -%}

{%- comment -%} WebSite + sitelinks SearchAction (home page only). {%- endcomment -%}
{%- if block.settings.enable_searchaction and template.name == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": {{ shop.url | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{%- endif -%}

{%- if article and block.settings.enable_article -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ article.title | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
    "author": { "@type": "Person", "name": {{ article.author | json }} },
    "publisher": { "@type": "Organization", "name": {{ shop.name | json }} }
    {%- if article.image %}
    ,"image": [{{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}]
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- comment -%} FAQPage from a product metafield (JSON list of {question, answer}). {%- endcomment -%}
{%- if product and block.settings.enable_faq -%}
  {%- assign faq = product.metafields[block.settings.faq_namespace][block.settings.faq_key] -%}
  {%- if faq != blank and faq.value != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for item in faq.value -%}
      { "@type": "Question", "name": {{ item.question | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ item.answer | json }} } }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
  {%- endif -%}
{%- endif -%}

{%- if block.settings.enable_localbusiness and block.settings.lb_name != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": {{ block.settings.lb_name | json }},
    "url": {{ shop.url | json }},
    {%- if block.settings.lb_phone != blank %}
    "telephone": {{ block.settings.lb_phone | json }},
    {%- endif %}
    "address": {
      "@type": "PostalAddress",
      "streetAddress": {{ block.settings.lb_street | json }},
      "addressLocality": {{ block.settings.lb_city | json }},
      "postalCode": {{ block.settings.lb_postal | json }},
      "addressCountry": {{ block.settings.lb_country | json }}
    }
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Pixelify SEO Schema",
  "target": "head",
  "settings": [
    { "type": "header", "content": "Structured data nodes" },
    { "type": "checkbox", "id": "enable_product", "label": "Product schema", "default": true },
    { "type": "checkbox", "id": "enable_breadcrumb", "label": "Breadcrumb schema", "default": true },
    { "type": "checkbox", "id": "enable_organization", "label": "Organization schema", "default": true },
    { "type": "checkbox", "id": "enable_aggregate_rating", "label": "Include rating in Product schema", "default": true },
    { "type": "header", "content": "Organization" },
    { "type": "text", "id": "org_name", "label": "Organization name" },
    { "type": "image_picker", "id": "org_logo", "label": "Logo" },
    { "type": "text", "id": "org_sameas", "label": "Social profile URLs (comma-separated)" },
    { "type": "header", "content": "Rating source (published metafield)" },
    { "type": "text", "id": "rating_namespace", "label": "Rating metafield namespace", "default": "custom" },
    { "type": "text", "id": "rating_key", "label": "Rating key", "default": "rating" },
    { "type": "text", "id": "rating_count_key", "label": "Rating count key", "default": "rating_count" },
    { "type": "header", "content": "More schema" },
    { "type": "checkbox", "id": "enable_searchaction", "label": "Sitelinks search box", "default": true },
    { "type": "checkbox", "id": "enable_article", "label": "Article schema (blog posts)", "default": true },
    { "type": "checkbox", "id": "enable_faq", "label": "FAQ schema (from metafield)", "default": false },
    { "type": "text", "id": "faq_namespace", "label": "FAQ metafield namespace", "default": "custom" },
    { "type": "text", "id": "faq_key", "label": "FAQ metafield key", "default": "faq" },
    { "type": "header", "content": "Local business" },
    { "type": "checkbox", "id": "enable_localbusiness", "label": "Emit LocalBusiness", "default": false },
    { "type": "text", "id": "lb_name", "label": "Business name" },
    { "type": "text", "id": "lb_phone", "label": "Phone" },
    { "type": "text", "id": "lb_street", "label": "Street address" },
    { "type": "text", "id": "lb_city", "label": "City" },
    { "type": "text", "id": "lb_postal", "label": "Postal code" },
    { "type": "text", "id": "lb_country", "label": "Country (ISO code)" }
  ]
}
{% endschema %}
