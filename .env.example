# pixelify-seo runtime env. Copy to .env and fill from the Shopify Partner dashboard.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,write_products,read_content,write_content,read_themes,write_themes,read_orders
# matches docker-compose.yml (port 5433 so it doesn't clash with pixelify-admin's 5432)
DATABASE_URL=postgresql://pixelify:pixelify@localhost:5433/pixelify_seo

# Optional integrations (features degrade gracefully if unset)
GOOGLE_CLIENT_ID=          # Search Console OAuth (app.gsc + auth.google)
GOOGLE_CLIENT_SECRET=      # Search Console token exchange (callback — scaffold)
AGENCY_CONSOLE_TOKEN=      # gate for the standalone /console?token=... agency view
CRON_SECRET=               # gate for GET /cron/audit?secret=... (scheduled re-audit + alerts)
