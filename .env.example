# pixelify-seo runtime env. Copy to .env and fill from the Shopify Partner dashboard.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://example.com
SCOPES=read_products,write_products,read_content,write_content,read_themes,write_themes,read_orders
# matches docker-compose.yml (port 5433 so it doesn't clash with pixelify-admin's 5432)
DATABASE_URL=postgresql://pixelify:pixelify@localhost:5433/pixelify_seo

# Encryption-at-rest key for stored server-side credentials (GA4 MP secret / Meta CAPI token / sGTM
# URL). 32 bytes as base64 or hex, e.g. `openssl rand -base64 32`. If unset, a key is derived from
# SHOPIFY_API_SECRET so the app still runs — but set this in production so credentials survive an
# app-secret rotation and can be rotated independently.
APP_ENCRYPTION_KEY=

# Background worker: shared secret for the /cron/tick endpoint (drains the delivery-retry outbox,
# refreshes FX rates, purges stale rows). Set a random value and configure a Railway cron service to
# hit `GET https://<app>/cron/tick` with header `x-cron-secret: <this>` (or `?key=<this>`) every few
# minutes. If unset, /cron/tick is closed (403) — retries won't drain and FX won't refresh.
CRON_SECRET=

# Google Ads Enhanced Conversions (direct upload). GATED: the whole feature stays hidden/inert unless
# all three are set AND a merchant connects + configures a customer + conversion action in-app. The
# developer token needs Google Ads API access (an approval process); the OAuth client is a Google
# Cloud "Web application" credential with redirect URI `<SHOPIFY_APP_URL>/google/oauth/callback`.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional: override the daily FX-rate source for multi-currency normalization (USD-based `rates` map).
FX_RATES_URL=

# Storefront-ingest rate limiting (/pixel/track, /apps/.../track). Defaults shown; raise for a very
# high-traffic store. Two ceilings per fixed window: per (shop+IP) and per shop across all IPs.
RATE_LIMIT_PER_IP=120
RATE_LIMIT_PER_SHOP=3000
RATE_LIMIT_WINDOW_SEC=60

# Billing is DEFINED but not enforced (the app is free). Set to `true` only when you decide to charge —
# then Pro-gated routes start requiring an active subscription. See app/lib/billing.server.js.
BILLING_ENFORCED=false

# Optional integrations (features degrade gracefully if unset)
AGENCY_CONSOLE_TOKEN=      # gate for the standalone /console?token=... agency view
